# ============================================================
# Kyro — TRIAGE-AI Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Flask
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-random-secret-key

# Server
HOST=0.0.0.0
PORT=5000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# AI Model
MODEL_PATH=app/ai/artifacts/xgb_severity_model.json
MODEL_VERSION=1.0.0
NHAMCS_DATA_PATH=data/nhamcs_ed_2022.csv

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=logs/kyro.log

# Future: Redis
# REDIS_URL=redis://localhost:6379/0

# Future: Multi-tenant
# HOSPITAL_ID=default
